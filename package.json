{
  "name": "opencode-stack",
  "version": "0.1.0",
  "description": "opencode 服务器的聚合服务程序，南向聚合连接多个 opencode 服务器，北向提供统一兼容接口",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --config nodemon.json src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js"
  },
  "keywords": [
    "opencode",
    "proxy",
    "aggregation"
  ],
  "author": "fellow99",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonc-parser": "^3.3.1",
    "log4js": "^6.9.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/log4js": "^0.0.33",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
